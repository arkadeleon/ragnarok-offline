    "Make sure all the servers are running before starting the game client." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stelle sicher, dass alle Server laufen, bevor du den Spiel-Client startest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asegúrate de que todos los servidores estén en ejecución antes de iniciar el cliente de juego."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assurez-vous que tous les serveurs sont en cours d’exécution avant de démarrer le client de jeu."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pastikan semua server sudah berjalan sebelum memulai klien game."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assicurati che tutti i server siano in esecuzione prima di avviare il client di gioco."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゲームクライアントを起動する前に、すべてのサーバーが稼働していることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "게임 클라이언트를 시작하기 전에 모든 서버가 실행 중인지 확인하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certifique-se de que todos os servidores estejam em execução antes de iniciar o cliente de jogo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перед запуском игрового клиента убедитесь, что все серверы запущены."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ตรวจสอบให้แน่ใจว่าเซิร์ฟเวอร์ทั้งหมดกำลังทำงานก่อนเริ่มไคลเอนต์เกม"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
